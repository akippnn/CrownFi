#!/usr/bin/env python3
"""Materialize allowlisted non-secret production configuration into the release manifest.

Secret values remain host-provisioned Podman secrets referenced by name. This
script is intentionally narrow so mutable GitHub environment variables cannot
arbitrarily rewrite the deployment manifest.
"""

from __future__ import annotations

import json
import os
from pathlib import Path
from urllib.parse import urlparse

MANIFEST = Path("arcturus.release.json")
R2_SECRET_TARGETS = {"R2_ACCESS_KEY_ID", "R2_SECRET_ACCESS_KEY"}


def required(name: str) -> str:
    value = os.environ.get(name, "").strip()
    if not value:
        raise SystemExit(f"{name} is required when CROWNFI_R2_ENABLED=true")
    return value


def positive_integer(name: str, default: str, minimum: int, maximum: int) -> str:
    raw = os.environ.get(name, default).strip()
    try:
        value = int(raw)
    except ValueError as exc:
        raise SystemExit(f"{name} must be an integer") from exc
    if not minimum <= value <= maximum:
        raise SystemExit(f"{name} must be between {minimum} and {maximum}")
    return str(value)


def validate_url(name: str, value: str, *, require_https: bool = True) -> str:
    parsed = urlparse(value)
    if not parsed.scheme or not parsed.netloc:
        raise SystemExit(f"{name} must be an absolute URL")
    if require_https and parsed.scheme != "https":
        raise SystemExit(f"{name} must use https")
    return value.rstrip("/")


with MANIFEST.open(encoding="utf-8") as stream:
    manifest = json.load(stream)

api = manifest["spec"]["components"]["api"]
environment = api.setdefault("environment", {})
secrets = api.setdefault("secrets", [])

for key in (
    "R2_ENDPOINT",
    "R2_BUCKET",
    "R2_PUBLIC_BASE_URL",
    "R2_UPLOAD_TTL_SECONDS",
    "R2_MAX_IMAGE_BYTES",
):
    environment.pop(key, None)

secrets[:] = [item for item in secrets if item.get("target") not in R2_SECRET_TARGETS]

enabled = os.environ.get("CROWNFI_R2_ENABLED", "false").strip().lower()
if enabled not in {"true", "false"}:
    raise SystemExit("CROWNFI_R2_ENABLED must be true or false")

if enabled == "true":
    endpoint = validate_url("R2_ENDPOINT", required("R2_ENDPOINT"))
    bucket = required("R2_BUCKET")
    public_base_url = validate_url("R2_PUBLIC_BASE_URL", required("R2_PUBLIC_BASE_URL"))
    ttl = positive_integer("R2_UPLOAD_TTL_SECONDS", "300", 30, 3600)
    max_bytes = positive_integer("R2_MAX_IMAGE_BYTES", "15728640", 1, 104857600)

    environment.update(
        {
            "R2_ENDPOINT": endpoint,
            "R2_BUCKET": bucket,
            "R2_PUBLIC_BASE_URL": public_base_url,
            "R2_UPLOAD_TTL_SECONDS": ttl,
            "R2_MAX_IMAGE_BYTES": max_bytes,
        }
    )
    secrets.extend(
        [
            {
                "name": "stellar-r2-access-key-id-20260716",
                "type": "env",
                "target": "R2_ACCESS_KEY_ID",
            },
            {
                "name": "stellar-r2-secret-access-key-20260716",
                "type": "env",
                "target": "R2_SECRET_ACCESS_KEY",
            },
        ]
    )

with MANIFEST.open("w", encoding="utf-8") as stream:
    json.dump(manifest, stream, indent=2)
    stream.write("\n")

print(f"Materialized production manifest with R2 enabled={enabled}.")
