# --- Supabase Postgres ---  (setup guide: SUPABASE.md in the repo root)
# Get both URLs from Supabase -> Connect -> ORMs -> Prisma. Replace <ref>, <pw>, <region>.
# DATABASE_URL = pooled (port 6543, keep ?pgbouncer=true). DIRECT_URL = direct (port 5432, migrations).
DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# --- Database ---
# For production, set a PostgreSQL/Supabase URL AND change provider in prisma/schema.prisma to "postgresql".

# --- Wallet provider ---
# mock | privy   (mock generates simulated Stellar addresses so the app runs with no keys)
WALLET_PROVIDER="mock"
# NEXT_PUBLIC_PRIVY_APP_ID=""
# PRIVY_APP_SECRET=""

# --- Stellar ---
# mock | live   (mock returns simulated tx hashes so anchoring/minting runs offline)
STELLAR_MODE="mock"
STELLAR_NETWORK="testnet"
STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
# Secret key used by the platform to sign anchor/mint transactions in live mode (server only).
# STELLAR_PLATFORM_SECRET=""
# Deployed contract ids (live mode)
# AUDIT_ANCHOR_CONTRACT_ID=""
# TICKET_CONTRACT_ID=""
# COLLECTIBLE_CONTRACT_ID=""
# SALE_SPLITTER_CONTRACT_ID=""
# USDC settlement for collectible purchases (buyer-signed via Freighter):
# USDC_TEST_CONTRACT_ID=""      # the mintable test-USDC token (contracts/usdc-test)
# DEMO_CONTESTANT_PAYOUT=""     # G... wallet that receives the contestant's cut in demo listings
# After deploying, register listings once:  npx tsx --env-file=.env scripts/register-listings.ts

# --- Voting ---
# Simple per-account vote quota per round.
VOTE_QUOTA_PER_ROUND="1"

# --- Rate limiting ---
# memory | upstash  (memory works out of the box; upstash for production)
RATELIMIT_MODE="memory"
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# --- Freighter / client Stellar network (Testnet for now) ---
NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# --- Admin wallets (comma-separated Stellar G... addresses) ---
NEXT_PUBLIC_ADMIN_WALLETS=""