{
  "name": "crownfi-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx prisma/seed.ts",
    "test:merkle": "tsx src/lib/merkle.test.ts",
    "test:ticketing": "tsx src/lib/ticketing.test.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "check": "npm run typecheck && npm run test:merkle && npm run test:ticketing",
    "security:audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@stellar/freighter-api": "^5.0.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "lucide-react": "^0.454.0",
    "next": "^15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
