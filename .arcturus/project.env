# Non-secret Arcturus project configuration. CLI flags and environment override it.
ARCTURUS_SERVICE=stellar-project
ARCTURUS_COMPONENT=web
ARCTURUS_PROJECT_SPEC=.arcturus/project-spec.json
ARCTURUS_SERVICE_TYPE=web
ARCTURUS_IMAGE_REPOSITORY=git.u128.org/mprojects/stellar-project/web
ARCTURUS_CONTAINERFILE=web/Dockerfile
ARCTURUS_VALIDATION_TARGETS=builder
ARCTURUS_RELEASE_TARGET=runtime
ARCTURUS_EXPOSURE=public
ARCTURUS_PORT=3000
ARCTURUS_DOMAIN=stellar-project.u128.org
ARCTURUS_TLS_MODE=portal
ARCTURUS_HEALTH_KIND=systemd
ARCTURUS_HEALTH_PATH=/api/health
ARCTURUS_PUBLIC_VERIFICATION=cloudflare-challenge
ARCTURUS_SCHEDULE=
ARCTURUS_RESTART=always
ARCTURUS_NETWORK=internal_routing
ARCTURUS_DEPLOY_URL=http://100.108.225.27:9090
ARCTURUS_CI=gitea
ARCTURUS_TEST_COMMAND=true
# CI supplies the published RC2-or-newer digest through the protected ARCTURUS_BUNDLE variable.
ARCTURUS_BUNDLE=
