# CrownFi canonical platform Compose defaults.
#
# Copy this file to infra/.env for a local smoke test. These values are safe
# only for a developer workstation and must be replaced in shared/staging
# environments.

POSTGRES_DB=crownfi
POSTGRES_USER=crownfi
POSTGRES_PASSWORD=crownfi-local-development-only
ADMIN_SESSION_SECRET=local-development-only-change-before-sharing

# Explicit runtime profiles. Local startup must never silently behave like
# Testnet or production.
CROWNFI_API_MODE=local
STELLAR_MODE=mock
WALLET_PROVIDER=mock

# Live/Testnet configuration is intentionally blank for the clean-clone path.
# Set STELLAR_MODE=live only after every required value is configured and the
# deployment registry has been verified.
STELLAR_PLATFORM_SECRET=
AUDIT_ANCHOR_CONTRACT_ID=
TICKET_CONTRACT_ID=
COLLECTIBLE_CONTRACT_ID=
SALE_SPLITTER_CONTRACT_ID=
USDC_TEST_CONTRACT_ID=
DEMO_CONTESTANT_PAYOUT=
EVENT_TREASURY_PAYOUT=
