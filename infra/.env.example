# Copy to infra/.env for Docker Compose overrides.
POSTGRES_DB=crownfi
POSTGRES_USER=crownfi
POSTGRES_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-with-openssl-rand-base64-32
CROWNFI_API_MODE=testnet
# For production, set to "live" and configure the contract addresses and platform secret below.
STELLAR_MODE=live
WALLET_PROVIDER=privy

# Stellar live-mode configuration:
STELLAR_PLATFORM_SECRET=replace-with-platform-secret-key-S...
AUDIT_ANCHOR_CONTRACT_ID=replace-with-audit-anchor-contract-id-C...
TICKET_CONTRACT_ID=replace-with-ticket-contract-id-C...
COLLECTIBLE_CONTRACT_ID=replace-with-collectible-contract-id-C...
SALE_SPLITTER_CONTRACT_ID=replace-with-sale-splitter-contract-id-C...
USDC_TEST_CONTRACT_ID=replace-with-usdc-test-contract-id-C...
DEMO_CONTESTANT_PAYOUT=replace-with-contestant-payout-wallet-G...
EVENT_TREASURY_PAYOUT=replace-with-event-treasury-wallet-G...
